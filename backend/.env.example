# ==================== Lakehouse Platform 配置 ====================
# 复制本文件为 .env 并按实际情况修改

# 服务端口
PORT=7071

# CORS 允许的来源（逗号分隔，可选）
# ALLOWED_ORIGINS=http://localhost:7071,http://127.0.0.1:7071

# ========== Flink ==========
# Flink REST API 地址
FLINK_BASE_URL=http://localhost:8081

# Flink 安装路径（WSL 内路径）
FLINK_HOME=/mnt/g/flink/flink-1.20.4

# Savepoint 存储目录（WSL 内路径）
FLINK_SAVEPOINT_DIR=/mnt/g/flink/savepoints

# ========== Apache Doris（MySQL 协议）==========
DORIS_HOST=127.0.0.1
DORIS_PORT=9130
DORIS_USER=root
DORIS_PASSWORD=

# ========== Paimon ==========
# Warehouse 路径（WSL 路径格式，如 /mnt/g/paimon_warehouse）
PAIMON_WAREHOUSE=/mnt/g/paimon_warehouse

# ========== 持久化存储 ==========
# Catalog/SQL Store/数据源/Datasource 等配置文件的存储目录
# 默认为系统临时目录，可自定义
# DATA_DIR=/tmp
